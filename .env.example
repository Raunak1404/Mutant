# ── Local desktop defaults ────────────────────────────────────────────────
APP_DATA_DIR=
JOB_RUNNER=local
USE_REDIS=false
EXECUTION_SERVICE_URL=embedded://local
API_HOST=127.0.0.1
API_PORT=8000
DEBUG=false

# ── LLM provider ─────────────────────────────────────────────────────────
# Use "claude" or "azure_openai"
LLM_PROVIDER=claude

# Claude (Anthropic)
ANTHROPIC_API_KEY=your-api-key-here
ANTHROPIC_MODEL=claude-sonnet-4-6

# Azure OpenAI (alternative)
AZURE_OPENAI_ENDPOINT=
AZURE_OPENAI_API_KEY=
AZURE_OPENAI_API_VERSION=2024-08-01-preview
AZURE_OPENAI_DEPLOYMENT=gpt-4o

# ── Database / storage ───────────────────────────────────────────────────
DATABASE_URL=
STORAGE_BACKEND=local
STORAGE_LOCAL_DIR=

# ── Optional S3 / MinIO ──────────────────────────────────────────────────
S3_BUCKET=weisiong
S3_ENDPOINT_URL=
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-east-1

# ── Optional Azure Blob ──────────────────────────────────────────────────
AZURE_STORAGE_CONNECTION_STRING=
AZURE_STORAGE_CONTAINER=weisiong

# ── Optional Redis / taskiq mode ─────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ── Runtime tuning ───────────────────────────────────────────────────────
RATE_LIMIT_RPM=50
RATE_LIMIT_TPM=100000
CACHE_ENABLED=true
CACHE_MEMORY_MAX_SIZE=512
CACHE_DISK_DIR=
CACHE_TTL_SECONDS=3600
CHUNK_SIZE_ROWS=100
REVIEW_CHUNK_SIZE_ROWS=300
MAX_WORKER_CONCURRENCY=10
STEPS_CODE_DIR=steps
LIBRARIES_DIR=libraries
